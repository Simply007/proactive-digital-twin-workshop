# Copy to .env and adjust if needed:  cp .env.example .env

# Where the agent's persistent files live on the HOST.
# Default keeps it outside the repo so the agent's state survives
# repo deletes and isn't accidentally committed.
AGENT_WORKSPACE=${HOME}/nanoclaw-workspace

# Bind address for OneCLI (the credential vault). 127.0.0.1 is correct
# for a single-laptop / single-host install. The compose file publishes
# this address to your host loopback so the URL the agent prints opens
# directly in your browser.
ONECLI_BIND_HOST=127.0.0.1

# Container name in your local Docker. Change if you want to run multiple
# sandboxes side by side.
SANDBOX_CONTAINER=agent-sandbox

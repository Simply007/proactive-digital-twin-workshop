# Copy to .env and adjust if needed:  cp .env.example .env

# NOTE: the agent's persistent state lives in a Docker NAMED VOLUME
# (`nanoclaw-work`, defined in docker-compose.yml), not a host directory.
# This is required so the agent's unix sockets land on a filesystem that
# supports unlink (Docker Desktop's macOS bind mount does not, which breaks
# service restart). State survives stop/start and down/up; wipe it with
# `./scripts/teardown.sh` (runs `docker compose down -v`). Inspect with:
#   docker compose exec -u nanoclaw sandbox bash

# Bind address for OneCLI (the credential vault). 127.0.0.1 is correct
# for a single-laptop / single-host install. The compose file publishes
# this address to your host loopback so the URL the agent prints opens
# directly in your browser.
ONECLI_BIND_HOST=127.0.0.1

# Container name in your local Docker. Change if you want to run multiple
# sandboxes side by side.
SANDBOX_CONTAINER=agent-sandbox
